    { "id": "shield", "name": { "en": "City Shields", "zh": "城市盾牌" }, "inputType": "number", "formula": "n*2", "description": { "en": "2 pts per shield", "zh": "每盾 2 分" } },
    { "id": "monastery", "name": { "en": "Completed Monastery", "zh": "完成的修道院" }, "inputType": "number", "formula": "9", "description": { "en": "9 pts each", "zh": "每个 9 分" } },
    { "id": "field", "name": { "en": "Field Cities (adj. completed)", "zh": "草地（邻接完成城市数）" }, "inputType": "number", "formula": "n*3", "description": { "en": "3 pts per adjacent city", "zh": "每邻接城市 3 分" } },
