    "setup": {
      "title": { "en": "Game Setup", "zh": "游戏准备" },
      "content": "1. 将 4 个大地图块儿放在四角，5 个小地图块儿排列在每两个大块儿之间\n2. 最近吃过榴莲的玩家先行动，顺时针方向\n3. 每人选择角色卡 + 棋子颜色\n4. 每人领取 **1000¥** 开局奖金\n5. 棋子放到起点\n\n🎯 **目标：最先拥有 10 座小屋的玩家获胜！**",
      "options": [
        { "label": { "en": "Start My Turn", "zh": "开始我的回合" }, "next": "roll" }
      ]
    },
    "roll": {
      "title": { "en": "Roll & Move", "zh": "掷骰前进" },
      "content": "投出 **1 枚骰子**，以 **逆时针** 方向前进对应点数。\n\n移动过程中经过起点可领取 200¥。\n\n你到达了什么类型的区块？",
      "options": [
        { "label": { "en": "Start", "zh": "起点" }, "next": "start" },
        { "label": { "en": "Shower Room", "zh": "淋浴间" }, "next": "shower" },
        { "label": { "en": "Forgot to Book Class", "zh": "忘记约课" }, "next": "forgot" },
        { "label": { "en": "Slacking Off", "zh": "摸鱼" }, "next": "slack" },
        { "label": { "en": "Unowned Facility", "zh": "无主项目" }, "next": "buy" },
        { "label": { "en": "My Own Facility", "zh": "自己的项目" }, "next": "own-facility" },
        { "label": { "en": "Other's Facility", "zh": "他人的项目" }, "next": "pay-fee" },
        { "label": { "en": "Other / Event", "zh": "其他 / 事件" }, "next": "event" }
      ]
    },
    "start": {
      "title": { "en": "Start Space", "zh": "起点" },
      "content": "工作一天辛苦啦！\n\n- **经过**起点：领取 **200¥**\n- **刚好停留**在起点：领取 **400¥**",
      "options": [
        { "label": { "en": "Check Win → End Turn", "zh": "检查胜利 → 结束回合" }, "next": "endcheck" }
      ]
    },
    "shower": {
      "title": { "en": "Shower Room", "zh": "淋浴间" },
      "content": "香香的淋浴间 🚿\n\n没有任何效果，安全区！",
      "options": [
        { "label": { "en": "End Turn", "zh": "结束回合" }, "next": "endcheck" }
      ]
    },
    "forgot": {
      "title": { "en": "Forgot to Book Class", "zh": "忘记约课" },
      "content": "忘记约课了！去淋浴间门口罚站！\n\n**倒退**至淋浴间（顺时针移动）。\n\n⚠️ 倒退过程中：\n- **不能**领取起点奖金\n- **不会**触发任何区域效果",
      "options": [
        { "label": { "en": "End Turn", "zh": "结束回合" }, "next": "endcheck" }
      ]
    },
    "slack": {
      "title": { "en": "Slacking Off", "zh": "摸鱼" },
