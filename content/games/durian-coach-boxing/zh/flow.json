    "victory": {
      "title": { "en": "Victory!", "zh": "胜利！" },
      "content": "🏆 恭喜！你成为了大拳馆的新教练！\n\n你是第一个拥有 10 座小屋的玩家！",
      "options": [
        { "label": { "en": "New Game", "zh": "新游戏" }, "next": "setup" }
      ]
